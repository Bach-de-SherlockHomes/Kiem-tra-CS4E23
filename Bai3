#include  <iostream>
#include <string>
using namespace std;
int main() {

    string b="";
    int count = 1;
    string a;
    cout << "Nhap cac ky tu viet thuong: ";
    cin >> a;
    for (int i=0;i<a.size();i++) {
        if (a[i]==a[i+1]) {
            count++;
        }
        else
        {
            b +=a[i]+std::to_string(count);
            count=1;
        }
    }

    cout << b<< endl;
}
